# ─────────────────────────────────────────────────────────────────────────────
# Polymarket Latency Arbitrage Bot — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Polymarket CLOB API ───────────────────────────────────────────────────────
# L2 API key obtained from https://polymarket.com (Settings → API)
POLY_API_KEY=your_polymarket_api_key_here

# L1 Ethereum private key (used for on-chain signing / L2 key derivation)
# This wallet must hold USDC on Polygon for live trading.
POLY_PRIVATE_KEY=0xyour_ethereum_private_key_here

# Optional: L2 API secret + passphrase (if using L2 auth)
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Create a bot via @BotFather and get the token
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Get this by messaging @userinfobot or adding the bot to a group
TELEGRAM_CHAT_ID=-100123456789

# ── Polygon RPC (Alchemy) ─────────────────────────────────────────────────────
# Sign up at https://alchemy.com, create a Polygon Mainnet app
ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_api_key_here

# ── Optional Overrides ────────────────────────────────────────────────────────
# Paper mode is always on by default unless --live --confirm --i-understand-risks
# are passed as CLI flags. These env vars let you adjust thresholds without
# editing source code.
# BOT_MIN_EDGE_PCT=5.0
# BOT_EXEC_EDGE_PCT=8.0
# BOT_MAX_PORTFOLIO_PCT=8.0
# BOT_MIN_LIQUIDITY_USD=50000
# BOT_DAILY_HALT_PCT=20.0
# BOT_DRAWDOWN_HALT_PCT=40.0
